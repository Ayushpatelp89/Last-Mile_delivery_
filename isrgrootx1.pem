  <script>
    function getColorScheme() {
      return localStorage.getItem('mantine-color-scheme')
    }

    function updateSEO() {
      if (window.location.hostname === 'console.tidb.io') {
        const script = document.createElement('script');
        script.type = 'application/ld+json';
        script.innerText = `{ "@context": "https://schema.org", "@type": "WebSite", "name": "TiDB Cloud", "alternateName": ["TiDB", "console.tidb.io"], "url": "https://console.tidb.io" }`;
        document.head.appendChild(script);
      }
    }

    function insertStyle(css) {
      var head = document.head || document.getElementsByTagName('head')[0]
      var style = document.createElement('style')

      if (!head) {
        return
      }

      style.appendChild(document.createTextNode(css))
      head.insertBefore(style, head.firstChild)
    }

    /**
     * @param {Object} item
     */
    function reportGA(item) {
      window.universalDataLayer = window.universalDataLayer || []
      window.universalDataLayer.push(item)
    }

    window.addEventListener('DOMContentLoaded', function () {
      var darkStyle = 'body { background-color: #111111; }'
      var lightStyle = 'body { background-color: #FFFFFF; }'

      // report page view event advance
      var pathname = window.location.pathname
      var allowedPaths = ['/free-trial', '/signup']
      if (allowedPaths.some((it) => pathname.startsWith(it))) {
        reportGA({ page_category: pathname.endsWith('/') ? pathname : pathname + '/' })
      }

      var colorScheme = getColorScheme()
      var isAuto = colorScheme === '"auto"'
      var isDark = colorScheme === '"dark"'
      var isLight = colorScheme === '"light"'

      if (!document.body) {
        return
      }

      updateSEO();

      // handle auto scheme
      if (isAuto && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return insertStyle(darkStyle)
      }


      if (isDark) {
        insertStyle(darkStyle)
      } else if (isLight) {
        insertStyle(lightStyle)
      }
    })
  </script>
